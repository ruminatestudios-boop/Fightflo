{
  "name": "feedback",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "node scripts/dev.mjs --clean",
    "prebuild": "node scripts/guard-build.mjs",
    "build": "next build",
    "postbuild": "node -e \"console.log('\\n  Styles apply after restart — run: npm run start  (or npm run prod for clean deploy)\\n')\"",
    "start": "lsof -ti:3001 2>/dev/null | xargs kill -9 2>/dev/null; PATH=\"$HOME/bin:/opt/homebrew/bin:/usr/local/bin:$PATH\" next start --port 3001",
    "prod": "rm -rf .next && npm run build && npm run start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify-setup": "node scripts/verify-setup.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@napi-rs/canvas": "^1.0.0",
    "@supabase/supabase-js": "^2.49.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^2.2.13",
    "cloudinary": "^2.6.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^173.0.0",
    "next": "^14.2.28",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1",
    "stripe": "^17.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.17.24",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.28",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2"
  }
}
