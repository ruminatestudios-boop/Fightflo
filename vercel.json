{
  "crons": [
    {
      "path": "/api/cron/notifications",
      "schedule": "0 17 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/feedback",
      "destination": "https://feedback.fightflo.app/feedback"
    },
    {
      "source": "/feedback/:path*",
      "destination": "https://feedback.fightflo.app/feedback/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/manifest.webmanifest",
      "destination": "/feedback/manifest.webmanifest",
      "permanent": false
    },
    {
      "source": "/feedback/feedback/:path*",
      "destination": "/feedback/:path*",
      "statusCode": 308
    }
  ]
}
